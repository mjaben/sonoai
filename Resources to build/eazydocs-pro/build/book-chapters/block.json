{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "eazydocs-pro/book-chapters",
  "version": "1.0.0",
  "title": "Book Chapters/Tutorials",
  "category": "eazydocs",
  "icon": "media-document",
  "description": "Displays documentation with tabs, sections, and auto-scrollspy navigation.",
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "docsSlugFormat": {
      "type": "string",
      "default": "1"
    },
    "exclude": {
      "type": "array",
      "default": []
    },
    "showSectionCount": {
      "type": "number",
      "default": 6
    },
    "pppDocItems": {
      "type": "number",
      "default": 6
    },
    "mainDocExcerpt": {
      "type": "number",
      "default": 15
    },
    "masonry": {
      "type": "boolean",
      "default": false
    },
    "order": {
      "type": "string",
      "default": "ASC"
    },
    "bookChapterPrefix": {
      "type": "string",
      "default": ""
    },
    "prefixAutoNumbering": {
      "type": "boolean",
      "default": true
    },
    "tabTitleTypography": {
      "type": "object",
      "default": {}
    },
    "tabTitleNormalColor": {
      "type": "string",
      "default": ""
    },
    "tabTitleActiveColor": {
      "type": "string",
      "default": ""
    },
    "tabTitleActiveBorderColor": {
      "type": "string",
      "default": ""
    },
    "docsTitleColor": {
      "type": "string",
      "default": ""
    },
    "docsTitleTypography": {
      "type": "object",
      "default": {}
    },
    "docsExcerptColor": {
      "type": "string",
      "default": ""
    },
    "docsExcerptTypography": {
      "type": "object",
      "default": {}
    },
    "itemTitleColor": {
      "type": "string",
      "default": ""
    },
    "itemTitleTypography": {
      "type": "object",
      "default": {}
    },
    "itemListTitleColor": {
      "type": "string",
      "default": ""
    },
    "itemListTitleHoverColor": {
      "type": "string",
      "default": ""
    },
    "itemListTitleTypography": {
      "type": "object",
      "default": {}
    },
    "itemBoxMargin": {
      "type": "object",
      "default": {
        "top": "",
        "right": "",
        "bottom": "",
        "left": ""
      }
    },
    "itemBoxPadding": {
      "type": "object",
      "default": {
        "top": "",
        "right": "",
        "bottom": "",
        "left": ""
      }
    },
    "itemBoxBorder": {
      "type": "object",
      "default": {
        "width": "",
        "style": "solid",
        "color": ""
      }
    },
    "itemBoxBorderRadius": {
      "type": "object",
      "default": {
        "top": "",
        "right": "",
        "bottom": "",
        "left": ""
      }
    },
    "itemBoxBackground": {
      "type": "string",
      "default": ""
    },
    "itemBoxBackgroundHover": {
      "type": "string",
      "default": ""
    },
    "itemBoxBorderHoverColor": {
      "type": "string",
      "default": ""
    },
    "itemBoxShadow": {
      "type": "object",
      "default": {}
    },
    "itemBoxShadowHover": {
      "type": "object",
      "default": {}
    },
    "blockId": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "eazydocs-pro",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}