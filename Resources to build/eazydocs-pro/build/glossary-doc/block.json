{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "eazydocs-pro/glossary-doc",
  "version": "1.0.0",
  "title": "EazyDocs Glossary Doc",
  "category": "eazydocs",
  "icon": "media-document",
  "description": "Displays glossary documentation.",
  "supports": {
    "html": false,
    "anchor": true,
    "align": [
      "wide",
      "full"
    ]
  },
  "attributes": {
    "doc": {
      "type": "string",
      "default": "all"
    },
    "docSecExcerpt": {
      "type": "number",
      "default": 8
    },
    "pppDocItems": {
      "type": "number",
      "default": 4
    },
    "order": {
      "type": "string",
      "default": "ASC"
    },
    "tooltip": {
      "type": "boolean",
      "default": false
    },
    "tooltipContentLimit": {
      "type": "number",
      "default": 40
    },
    "readMore": {
      "type": "string",
      "default": "Read More"
    },
    "sectionBtn": {
      "type": "boolean",
      "default": true
    },
    "sectionBtnTxt": {
      "type": "string",
      "default": "View More"
    },
    "sectionBtnUrl": {
      "type": "string",
      "default": ""
    },
    "showMoreBtn": {
      "type": "string",
      "default": "View All"
    },
    "showLessBtn": {
      "type": "string",
      "default": "Show Less"
    },
    "alphabetColor": {
      "type": "string",
      "default": ""
    },
    "alphabetBackground": {
      "type": "string",
      "default": ""
    },
    "searchBoxPadding": {
      "type": "object",
      "default": {}
    },
    "searchBoxBorder": {
      "type": "object",
      "default": {}
    },
    "searchBoxBackground": {
      "type": "string",
      "default": ""
    },
    "searchBoxFocusBackground": {
      "type": "string",
      "default": ""
    },
    "searchBoxBorderRadius": {
      "type": "object",
      "default": {}
    },
    "searchPlaceholderColor": {
      "type": "string",
      "default": ""
    },
    "searchTextColor": {
      "type": "string",
      "default": ""
    },
    "docAlphabetColor": {
      "type": "string",
      "default": ""
    },
    "docAlphabetBackground": {
      "type": "string",
      "default": ""
    },
    "docContentColor": {
      "type": "string",
      "default": ""
    },
    "docContentIconColor": {
      "type": "string",
      "default": ""
    },
    "boxBackground": {
      "type": "string",
      "default": ""
    },
    "boxBorder": {
      "type": "object",
      "default": {}
    },
    "boxPadding": {
      "type": "object",
      "default": {}
    },
    "titleColor": {
      "type": "string",
      "default": ""
    },
    "subtitleColor": {
      "type": "string",
      "default": ""
    },
    "contentTitleColor": {
      "type": "string",
      "default": ""
    },
    "contentBodyColor": {
      "type": "string",
      "default": ""
    },
    "isBgObjects": {
      "type": "boolean",
      "default": true
    },
    "isRound1": {
      "type": "boolean",
      "default": true
    },
    "round1Color": {
      "type": "string",
      "default": ""
    },
    "isRound2": {
      "type": "boolean",
      "default": true
    },
    "round2Color": {
      "type": "string",
      "default": ""
    },
    "tooltipPadding": {
      "type": "object",
      "default": {}
    },
    "tooltipBackground": {
      "type": "string",
      "default": ""
    },
    "tooltipBorderRadius": {
      "type": "object",
      "default": {}
    },
    "tooltipTitleColor": {
      "type": "string",
      "default": ""
    },
    "tooltipContentColor": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "eazydocs-pro",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style.css",
  "viewScript": [
    "mixitup",
    "eazydocs-pro-frontend",
    "eazydocs-tooltip"
  ],
  "render": "file:./render.php"
}